const EventEmitter = require('events');

class MessageBus extends EventEmitter {}
const bus = new MessageBus();

class Sender {
    send(message) {
        console.log(`\n[Sender] Sending: ${message}`);
        bus.emit('message', message);
    }
}

class Logger {
    constructor() {
        this.listener = (msg) => {
            console.log(`[Logger] Received: ${msg}`);
        };

        bus.on('message', this.listener);
    }

    unsubscribe() {
        bus.off('message', this.listener);
        console.log('[Logger] Unsubscribed');
    }
}

class Analyzer {
    constructor() {
        this.listener = (msg) => {
            console.log(`[Analyzer] Message length: ${msg.length}`);
        };

        bus.on('message', this.listener);
    }

    unsubscribe() {
        bus.off('message', this.listener);
        console.log('[Analyzer] Unsubscribed');
    }
}

class AutoResponder {
    constructor() {
        this.listener = (msg) => {
            if (msg.includes('hello')) {
                console.log('[AutoResponder] Reply: Hi there!');
            }
        };

        bus.on('message', this.listener);
    }

    unsubscribe() {
        bus.off('message', this.listener);
        console.log('[AutoResponder] Unsubscribed');
    }
}