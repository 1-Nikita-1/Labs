const fs = require("fs");

function writeLog(message) {
    console.log(message);

    fs.appendFileSync("app.log", message + "\n");
}

function formatLog(level, functionName, args, result = null, error = null, execTime = null) {

    return JSON.stringify({
        timestamp: new Date().toISOString(),
        level: level,
        function: functionName,
        arguments: args,
        result: result,
        error: error ? error.message : null,
        execution_time_ms: execTime
    }, null, 4);
}

function log(level = "INFO", logErrorsOnly = false) {

    return function (func) {

        return async function (...args) {

            const startTime = Date.now();

            try {

                const result = await func(...args);

                const execTime = Date.now() - startTime;

                if (!logErrorsOnly) {

                    const message = formatLog(
                        level,
                        func.name,
                        args,
                        result,
                        null,
                        execTime
                    );

                    writeLog(message);
                }

                return result;

            } catch (error) {

                const execTime = Date.now() - startTime;

                const message = formatLog(
                    "ERROR",
                    func.name,
                    args,
                    null,
                    error,
                    execTime
                );

                writeLog(message);

                throw error;
            }
        };
    };
}

const add = log("INFO")(function add(a, b) {
    return a + b;
});

const divide = log("ERROR", true)(function divide(a, b) {
    return a / b;
});

const asyncTask = log("DEBUG")(async function asyncTask(seconds) {

    return new Promise((resolve) => {

        setTimeout(() => {
            resolve(`Task completed in ${seconds} second(s)`);
        }, seconds * 1000);

    });
});

async function main() {

    console.log("SYNC FUNCTION:");
    await add(10, 5);

    console.log("\nERROR LOGGING:");

    try {
        await divide(10, 0);
    } catch (error) {
    }

    console.log("\nASYNC FUNCTION:");
    await asyncTask(2);
}

main();