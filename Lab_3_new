function memoize(fn, options = {}) {
    const {
        maxSize = Infinity,
        policy = "LRU"
    } = options;

    const cache = new Map();
    const meta = new Map();

    function getKey(args) {
        return JSON.stringify(args);
    }

    function evict() {
        if (cache.size <= maxSize) return;

        if (policy === "LRU") {
            const oldestKey = cache.keys().next().value;

            cache.delete(oldestKey);
            meta.delete(oldestKey);

        } else if (policy === "LFU") {
            let leastKey;
            let minCount = Infinity;

            for (let [key, data] of meta.entries()) {
                if (data.count < minCount) {
                    minCount = data.count;
                    leastKey = key;
                }
            }

            cache.delete(leastKey);
            meta.delete(leastKey);
        }
    }

    return function (...args) {
        const key = getKey(args);

        if (cache.has(key)) {
            const value = cache.get(key);
            const data = meta.get(key);

            data.count++;

            if (policy === "LRU") {
                cache.delete(key);
                cache.set(key, value);
            }

            console.log("From cache:", key);
            return value;
        }

        const result = fn(...args);

        cache.set(key, result);

        meta.set(key, {
            count: 1
        });

        evict();

        console.log("Calculated:", key);
        return result;
    };
}

const slowSquare = (x) => x * x;

console.log("LRU:");
const memoLRU = memoize(slowSquare, {
    maxSize: 2,
    policy: "LRU"
});

memoLRU(1);
memoLRU(2);
memoLRU(1);
memoLRU(3);
memoLRU(2);

console.log("\nLFU:");
const memoLFU = memoize(slowSquare, {
    maxSize: 2,
    policy: "LFU"
});

memoLFU(1);
memoLFU(2);
memoLFU(1);
memoLFU(3);